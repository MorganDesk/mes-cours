properties:
  file.name:
    displayName: Titre du module
views:
  - type: table
    name: Tableau
    filters:
      and:
        - theme == "Calcul littéral"
    order:
      - file.name
      - description
      - draft
    summaries:
      file.mtime: Earliest
    columnSize:
      note.description: 402
