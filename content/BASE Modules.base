views:
  - type: table
    name: Tableau
    filters:
      and:
        - file.inFolder("Modules")
    order:
      - file.name
      - description
      - theme
      - draft
    sort:
      - property: file.tags
        direction: ASC
      - property: file.ctime
        direction: DESC
    columnSize:
      file.name: 156
      note.theme: 108
      note.draft: 65
