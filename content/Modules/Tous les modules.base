views:
  - type: table
    name: Tableau
    filters:
      and:
        - file.inFolder("Modules")
        - file.name != "index"
        - file.ext != "base"
    order:
      - file.name
      - description
      - theme
      - draft
    sort:
      - property: file.name
        direction: ASC
    columnSize:
      file.name: 156
      note.theme: 108
      note.draft: 65
